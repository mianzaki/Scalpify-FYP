# GASP-AI API Configuration Example
# Copy this file to .env and fill in your actual values

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME="GASP-AI"
VERSION="1.0.0"
DEBUG=True
API_V1_STR="/api/v1"

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
HOST=0.0.0.0
PORT=8000
WORKERS=2

# =============================================================================
# CORS & SECURITY SETTINGS
# =============================================================================
# Comma-separated list of allowed origins, use ["*"] for development
CORS_ORIGINS=["*"]
# Comma-separated list of allowed hosts
ALLOWED_HOSTS=["51.21.1.14", "172.31.23.128", "localhost"]

# =============================================================================
# FILE UPLOAD SETTINGS
# =============================================================================
# Maximum file size in bytes (10MB = 10485760)
MAX_FILE_SIZE=10485760
# Allowed file extensions (JSON array format)
ALLOWED_EXTENSIONS=[".jpg", ".jpeg", ".png", ".bmp"]
# Allowed MIME types (JSON array format)
ALLOWED_MIME_TYPES=["image/jpeg", "image/png", "image/bmp"]

# =============================================================================
# SUPABASE DATABASE CONFIGURATION
# =============================================================================
# Get these from your Supabase project dashboard (Settings > API)
# Leave empty to run in development mode without database
SUPABASE_URL=https://hqguofajlcnnmbrwawqu.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImhxZ3VvZmFqbGNubm1icndhd3F1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTYwNjY1ODgsImV4cCI6MjA3MTY0MjU4OH0.KEcx9cua6eKVNU2wYprZuBJQ7_iwuIDBSQO35s2xYuA
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImhxZ3VvZmFqbGNubm1icndhd3F1Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc1NjA2NjU4OCwiZXhwIjoyMDcxNjQyNTg4fQ.u7qtrmNNRXxjnkW608li9mcitBx5SFFWydjVCj1zQI8

# Database table names (customize if needed)
SUPABASE_SESSIONS_TABLE=analysis_sessions
SUPABASE_RESULTS_TABLE=analysis_results

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================
# Path to your trained YOLO model (relative to api/ directory)
MODEL_PATH=../model/best.pt
# Device to run inference on (cpu/cuda/mps)
DEVICE=cpu
# Model confidence threshold (0.0 - 1.0)
MODEL_CONFIDENCE=0.25
# Model IoU threshold for NMS (0.0 - 1.0)
MODEL_IOU=0.4

# =============================================================================
# STORAGE CONFIGURATION
# =============================================================================
# Directory to store uploaded images (relative to api/ directory)
UPLOAD_DIR=../uploads
# Directory to store annotated results (relative to api/ directory)
OUTPUT_DIR=../output
# Maximum storage per user in MB (0 = unlimited)
MAX_STORAGE_PER_USER=100

# =============================================================================
# LOGGING & MONITORING
# =============================================================================
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
# Log file path (leave empty to log to console only)
LOG_FILE=
# Enable performance monitoring
ENABLE_METRICS=True

# =============================================================================
# REDIS CONFIGURATION (Optional - for caching and rate limiting)
# =============================================================================
# Redis connection URL (leave empty to disable Redis features)
REDIS_URL=
# Session cache TTL in seconds
CACHE_TTL=3600

# =============================================================================
# EMAIL CONFIGURATION (Optional - for notifications)
# =============================================================================
# SMTP settings for email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=True
FROM_EMAIL=noreply@your-domain.com

# =============================================================================
# API RATE LIMITING
# =============================================================================
# Requests per minute per IP
RATE_LIMIT_PER_MINUTE=30
# Maximum concurrent requests per IP
MAX_CONCURRENT_REQUESTS=5

# =============================================================================
# AUTHENTICATION (Optional - for protected endpoints)
# =============================================================================
# JWT secret key (generate a secure random key)
JWT_SECRET_KEY=your-super-secret-jwt-key-here
# JWT token expiration time in hours
JWT_EXPIRATION_HOURS=24
# Enable API key authentication
ENABLE_API_KEY_AUTH=False
# Valid API keys (comma-separated)
API_KEYS=

# =============================================================================
# EXTERNAL SERVICES (Optional)
# =============================================================================
# AWS S3 for file storage (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# Sentry for error tracking (optional)
SENTRY_DSN=

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Enable detailed error responses (disable in production)
DEBUG_RESPONSES=False
# Enable Swagger/OpenAPI docs (disable in production)
ENABLE_DOCS=True
# Enable profiling middleware
ENABLE_PROFILING=False
